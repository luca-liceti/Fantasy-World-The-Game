# =============================================================================
# Git LFS Tracking Rules
# GitHub hard limit: 100 MB per file (files above this CANNOT be pushed without LFS)
# GitHub warning:     50 MB per file (push still works but Git warns you)
#
# Git does not support size-based LFS triggers natively. The standard practice
# for game projects is to route ALL binary asset types through LFS, since these
# are the files that grow large and are not human-readable by Git anyway.

# --- Audio ---
*.ogg  filter=lfs diff=lfs merge=lfs -text
*.wav  filter=lfs diff=lfs merge=lfs -text
*.mp3  filter=lfs diff=lfs merge=lfs -text
*.flac filter=lfs diff=lfs merge=lfs -text
*.aac  filter=lfs diff=lfs merge=lfs -text
*.opus filter=lfs diff=lfs merge=lfs -text
# --- Video ---
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
*.avi  filter=lfs diff=lfs merge=lfs -text
*.mov  filter=lfs diff=lfs merge=lfs -text
*.mkv  filter=lfs diff=lfs merge=lfs -text
# --- 3D Models ---
*.glb   filter=lfs diff=lfs merge=lfs -text
*.gltf  filter=lfs diff=lfs merge=lfs -text
*.fbx   filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.obj   filter=lfs diff=lfs merge=lfs -text
*.dae   filter=lfs diff=lfs merge=lfs -text
# --- Textures / Images ---
