# Godot 4+ specific ignores
.godot/
/android/

# =========================================
# Large Assets (managed via Syncthing)
# =========================================

# Textures (can be huge - 50-100+ MB)
assets/textures/

# 3D Models
assets/models/

# HDRI Environment Maps
assets/hdri/

# Audio Files
assets/music/
assets/sfx/

# Logo/branding assets
assets/logo/

# BUT: Keep shaders in Git (they're code)
!assets/shaders/

# =========================================
# Keep in Git: Code, Scenes, Data
# =========================================
# Everything else (scripts/, scenes/, data/) stays in Git
