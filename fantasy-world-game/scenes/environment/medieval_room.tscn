[gd_scene load_steps=6 format=3 uid="uid://medieval_room_scene"]

[ext_resource type="Script" path="res://scripts/environment/medieval_room.gd" id="1_medieval_room"]
[ext_resource type="Script" path="res://scripts/environment/medieval_room_setup.gd" id="2_room_setup"]

; =============================================================================
; MEDIEVAL ROOM ENVIRONMENT
; A scholar's study room - replaces the HDRI background
; Contains: Stone walls, wooden floor, door, window, fireplace
; Props: Books, candles, scrolls, potions, furniture
; =============================================================================

; -----------------------------------------------------------------------------
; MATERIALS (used as fallback/placeholder)
; -----------------------------------------------------------------------------

[sub_resource type="StandardMaterial3D" id="stone_wall_material"]
resource_name = "StoneWall"
albedo_color = Color(0.4, 0.38, 0.35, 1)
roughness = 0.92
metallic = 0.0
uv1_triplanar = true
uv1_world_triplanar = true
uv1_scale = Vector3(0.3, 0.3, 0.3)

[sub_resource type="StandardMaterial3D" id="wood_floor_material"]
resource_name = "WoodFloor"
albedo_color = Color(0.22, 0.16, 0.10, 1)
roughness = 0.7
metallic = 0.0
uv1_triplanar = true
uv1_world_triplanar = true
uv1_scale = Vector3(0.15, 0.15, 0.15)

[sub_resource type="StandardMaterial3D" id="ceiling_material"]
resource_name = "StoneCeiling"
albedo_color = Color(0.35, 0.33, 0.30, 1)
roughness = 0.95
metallic = 0.0
uv1_triplanar = true
uv1_world_triplanar = true
uv1_scale = Vector3(0.25, 0.25, 0.25)

; =============================================================================
; SCENE TREE
; =============================================================================

[node name="MedievalRoom" type="Node3D"]
script = ExtResource("1_medieval_room")

; -----------------------------------------------------------------------------
; ROOM STRUCTURE - CSG fallback geometry
; This is hidden when PropSetup.build_room_architecture = true
; Keep for fallback/testing without 3D models
; -----------------------------------------------------------------------------
[node name="RoomStructure" type="Node3D" parent="."]
; HIDDEN - Room is built from 3D models by PropSetup
visible = false

; Floor
[node name="Floor" type="CSGBox3D" parent="RoomStructure"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.25, 0)
use_collision = true
size = Vector3(12, 0.5, 12)
material = SubResource("wood_floor_material")

; Back Wall
[node name="WallBack" type="CSGBox3D" parent="RoomStructure"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3, -6)
use_collision = true
size = Vector3(12, 7, 0.8)
material = SubResource("stone_wall_material")

; Left Wall
[node name="WallLeft" type="CSGBox3D" parent="RoomStructure"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -6, 3, 0)
use_collision = true
size = Vector3(0.8, 7, 12)
material = SubResource("stone_wall_material")

; Right Wall
[node name="WallRight" type="CSGBox3D" parent="RoomStructure"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 6, 3, 0)
use_collision = true
size = Vector3(0.8, 7, 12)
material = SubResource("stone_wall_material")

; Front Wall
[node name="WallFront" type="CSGBox3D" parent="RoomStructure"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3, 6)
use_collision = true
size = Vector3(12, 7, 0.8)
material = SubResource("stone_wall_material")

; Ceiling
[node name="Ceiling" type="CSGBox3D" parent="RoomStructure"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 6.75, 0)
use_collision = true
size = Vector3(12, 0.5, 12)
material = SubResource("ceiling_material")

; -----------------------------------------------------------------------------
; PROP SETUP - Builds the room from downloaded 3D models
; This script:
;   1. Builds room architecture (walls, floor, door, window)
;   2. Places the main table
;   3. Adds all table props (books, candles, scrolls, etc.)
;   4. Adds room furniture (chairs, barrels, bookcases, etc.)
;   5. Sets up dynamic lighting (candles, torches, fireplace)
; -----------------------------------------------------------------------------
[node name="PropSetup" type="Node3D" parent="."]
script = ExtResource("2_room_setup")
prop_scale = 1.0
village_scale = 1.0
dungeon_scale = 0.01
enable_candle_lights = true
enable_fireplace_light = true
build_room_architecture = true

; -----------------------------------------------------------------------------
; PRIMARY LIGHTING - Scene lights for main illumination
; The PropSetup script adds additional dynamic lights
; -----------------------------------------------------------------------------
[node name="Lighting" type="Node3D" parent="."]

; Main table candle (primary light source)
[node name="MainCandleLight" type="OmniLight3D" parent="Lighting"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.5, 1.5, 0)
light_color = Color(1.0, 0.85, 0.6, 1)
light_energy = 2.5
light_indirect_energy = 0.8
omni_range = 8.0
omni_attenuation = 1.2
shadow_enabled = true

; Secondary candle
[node name="SecondaryCandleLight" type="OmniLight3D" parent="Lighting"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -1.0, 1.3, 0.3)
light_color = Color(1.0, 0.8, 0.55, 1)
light_energy = 1.5
light_indirect_energy = 0.5
omni_range = 5.0
omni_attenuation = 1.3
shadow_enabled = true

; Fireplace (warm orange glow from right side)
[node name="FireplaceLight" type="OmniLight3D" parent="Lighting"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 5.5, 0.8, 0)
light_color = Color(1.0, 0.45, 0.15, 1)
light_energy = 5.0
light_indirect_energy = 1.2
omni_range = 12.0
omni_attenuation = 0.9
shadow_enabled = true

; Window light (cool moonlight from left wall)
[node name="WindowLight" type="SpotLight3D" parent="Lighting"]
transform = Transform3D(0.866, 0, 0.5, 0, 1, 0, -0.5, 0, 0.866, -5.5, 2.5, -2)
light_color = Color(0.6, 0.7, 0.9, 1)
light_energy = 2.0
light_indirect_energy = 0.3
spot_range = 10.0
spot_angle = 45.0
shadow_enabled = true

; Chandelier (ceiling centerpiece)
[node name="ChandelierLight" type="OmniLight3D" parent="Lighting"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 5.5, 0)
light_color = Color(1.0, 0.85, 0.6, 1)
light_energy = 3.5
light_indirect_energy = 0.6
omni_range = 14.0
omni_attenuation = 1.1
shadow_enabled = true

; Ambient fill (very low, prevents pure black)
[node name="AmbientFill" type="DirectionalLight3D" parent="Lighting"]
transform = Transform3D(0.707, -0.5, 0.5, 0, 0.707, 0.707, -0.707, -0.5, 0.5, 0, 8, 0)
light_color = Color(0.3, 0.25, 0.2, 1)
light_energy = 0.1
light_indirect_energy = 0.15
shadow_enabled = false

; -----------------------------------------------------------------------------
; GAME BOARD MOUNT POINT
; The hex board is placed here, on top of the table
; Position matches table surface height
; -----------------------------------------------------------------------------
[node name="GameBoardMount" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, 0)
