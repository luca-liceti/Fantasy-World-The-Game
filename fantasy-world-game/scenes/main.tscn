[gd_scene load_steps=4 format=3 uid="uid://physical_medieval_room"]

[ext_resource type="Script" path="res://scripts/main.gd" id="1_main"]
[ext_resource type="PackedScene" uid="uid://c1xk5l8nvt2qr" path="res://scenes/board/hex_board.tscn" id="2_hex_board"]
[ext_resource type="Script" path="res://scripts/environment/physical_room_builder.gd" id="3_room_builder"]

; =============================================================================
; FANTASY WORLD — MAIN GAME SCENE
; =============================================================================
;
; Environment is loaded at runtime by EnvironmentBuilder (PhysicalRoom node).
; Lighting is set to bright, even, Blender-viewport style for development —
; easy to see alignment, scaling, and model fit.
;
; To restore atmospheric lighting later, replace this Environment sub-resource
; with the desired mood settings (fog, SSAO, glow, etc.).
; =============================================================================

; -----------------------------------------------------------------------------
; BRIGHT DEVELOPMENT ENVIRONMENT (Blender viewport style)
; Everything visible, no atmospheric effects, even illumination
; -----------------------------------------------------------------------------
[sub_resource type="Environment" id="Environment_dev"]
; Solid dark-gray background (neutral, like Blender's viewport)
background_mode = 1
background_color = Color(0.22, 0.22, 0.25, 1)

; Strong ambient light — fills all shadows so geometry is clearly visible
ambient_light_source = 1
ambient_light_color = Color(1.0, 1.0, 1.0, 1)
ambient_light_energy = 0.8

; Use scene geometry for reflected light
reflected_light_source = 1

; Linear tonemap — no cinematic grading, raw colors
tonemap_mode = 0
tonemap_exposure = 1.0

; Everything below is intentionally OFF for dev clarity
ssao_enabled = false
ssil_enabled = false
fog_enabled = false
volumetric_fog_enabled = false
glow_enabled = false
ssr_enabled = false
sdfgi_enabled = false

; =============================================================================
; SCENE TREE
; =============================================================================

[node name="Main" type="Node3D"]
script = ExtResource("1_main")

; World environment with bright dev settings
[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Environment_dev")

; -----------------------------------------------------------------------------
; DEVELOPMENT LIGHTS — Bright, even, shadow-free (like Blender viewport)
; Two directional lights from opposite angles for uniform illumination.
; Replace these with atmospheric lighting when ready for final look.
; -----------------------------------------------------------------------------

; Main light: above and slightly in front, pointing down at ~45°
[node name="DevLight_Main" type="DirectionalLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.707107, -0.707107, 0, 0.707107, 0.707107, 0, 10, 0)
light_color = Color(1, 1, 1, 1)
light_energy = 1.5
shadow_enabled = false

; Fill light: from the opposite side, softer, to eliminate dark areas
[node name="DevLight_Fill" type="DirectionalLight3D" parent="."]
transform = Transform3D(-1, 0, 0, 0, 0.707107, 0.707107, 0, 0.707107, -0.707107, 0, 10, 0)
light_color = Color(0.9, 0.92, 1.0, 1)
light_energy = 0.8
shadow_enabled = false

; =============================================================================
; ENVIRONMENT MODEL
; Loads a pre-made .glb room/scene and positions it around the board.
; Adjust position_offset, rotation_degrees_y, and environment_scale
; in the Inspector to align the model's table with the board.
; =============================================================================
[node name="PhysicalRoom" type="Node3D" parent="."]
script = ExtResource("3_room_builder")

; =============================================================================
; HEX BOARD — Game board (sits on top of the environment's table surface)
; Y = 0.9 is the board's world height; the environment model should be
; scaled/positioned so its table surface matches this.
; =============================================================================
[node name="HexBoard" parent="." instance=ExtResource("2_hex_board")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, 0)

; =============================================================================
; GAME UI — 2D interface overlay
; =============================================================================
[node name="GameUI" type="CanvasLayer" parent="."]
