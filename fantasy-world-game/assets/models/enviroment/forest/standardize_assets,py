import bpy
import os

# --- CONFIGURATION ---
THRESHOLD_MB = 50.0  
REDUCTION_RATIO = 0.05

input_dir = os.getcwd()
output_dir = os.path.join(input_dir, "optimized_assets")

if not os.path.exists(output_dir):
    os.makedirs(output_dir)

def get_real_size_mb(file_path):
    """Calculates size of the file plus its associated .bin if applicable."""
    total_size = os.path.getsize(file_path)
    
    # Check for the external binary file common in Poly Haven gltf downloads
    base_name = os.path.splitext(file_path)[0]
    bin_path = base_name.replace("_2k", "") + ".bin"
    
    if os.path.exists(bin_path):
        total_size += os.path.getsize(bin_path)
    
    return total_size / (1024 * 1024)

def process_file(file_path, export_path, should_decimate):
    # Reset Blender scene
    bpy.ops.wm.read_factory_settings(use_empty=True)
    
    # Import the asset
    bpy.ops.import_scene.gltf(filepath=file_path)
    
    if should_decimate:
        print(f"[DECIMATE] Heavy model detected: {os.path.basename(file_path)}")
        for obj in bpy.context.scene.objects:
            if obj.type == 'MESH':
                bpy.context.view_layer.objects.active = obj
                mod = obj.modifiers.new(name="Decimate", type='DECIMATE')
                mod.ratio = REDUCTION_RATIO
                bpy.ops.object.modifier_apply(modifier="Decimate")
    else:
        print(f"[CONVERT] Preserving quality for: {os.path.basename(file_path)}")
            
    # Export EVERY file as a single Binary .glb
    # This combines geometry and textures into one file for Godot
    bpy.ops.export_scene.gltf(
        filepath=export_path, 
        export_format='GLB',
        export_apply=True
    )

print(f"Working in: {input_dir}")

for filename in os.listdir(input_dir):
    # Target gltf and existing glb files
    if filename.lower().endswith((".gltf", ".glb")):
        if "_opt" in filename: 
            continue
            
        full_input_path = os.path.join(input_dir, filename)
        size_mb = get_real_size_mb(full_input_path)
        
        # Standardize the output name to [original]_opt.glb
        clean_name = os.path.splitext(filename)[0] + "_opt.glb"
        full_output_path = os.path.join(output_dir, clean_name)
        
        decimate_flag = size_mb > THRESHOLD_MB
        
        try:
            process_file(full_input_path, full_output_path, decimate_flag)
        except Exception as e:
            print(f"Error processing {filename}: {e}")

print(f"\nStandardization Complete! All models are now .glb in: {output_dir}")
