# =============================================================================
# .gitignore — Fantasy World: The Game
# =============================================================================

# -----------------------------------------------------------------------------
# Godot Engine — Generated Cache
# Fully regenerated by the editor on first open. Never commit this.
# -----------------------------------------------------------------------------
fantasy-world-game/.godot/

# Godot runtime log (generated each session, not useful in version control)
fantasy-world-game/godot_log.txt

# NOTE: .import files are intentionally tracked.
# They allow the project to open on other machines without a full re-import.

# -----------------------------------------------------------------------------
# Biome Decoration Datapacks
# These files can be re-downloaded from their origin website.
# -----------------------------------------------------------------------------
biome_decoration (datapacks)/

# -----------------------------------------------------------------------------
# Operating System Junk
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Editor / IDE Metadata
# -----------------------------------------------------------------------------
# Visual Studio Code
.vscode/

# JetBrains (Rider, etc.)
.idea/
*.iml

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# Other IDE
.specstory
.cursorindexingignore

# -----------------------------------------------------------------------------
# Build Artifacts & Exports
# (Godot export output — not source, not needed in version control)
# -----------------------------------------------------------------------------
build/
export/
dist/

